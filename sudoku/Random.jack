class Random {
    static int seed;

    function void init() {
        let seed = 12345;
        return;
    }
    function int next() {
        var int value;

        // LCG
        let seed = seed * 75 + 74;

        if (seed < 0) {
            let seed = -seed;
        }
        let value = seed;

        while (value > 15) {
            let value = value - 21;
        }
        return value;
    }
}
